{%- comment -%}
  Songs list for the playground — renders the first N tracks of a public
  NetEase playlist from _data/playlist_tracks.json (no playlist name shown).
  Refresh the data with: python3 scripts/fetch_liked_songs.py
{%- endcomment -%}
{%- assign data = site.data.playlist_tracks -%}
{%- if data and data.tracks and data.tracks.size > 0 -%}
<div class="pg-songs">
  <ol class="pg-tracklist">
    {%- for t in data.tracks limit:10 -%}
      <li class="pg-track">
        <span class="pg-track-n">{{ forloop.index }}</span>
        <a class="pg-track-cover" href="{{ t.url }}" target="_blank" rel="noopener" aria-label="{{ t.title }} on NetEase Cloud Music">
          <img src="{{ t.cover }}" alt="" loading="lazy" width="48" height="48">
        </a>
        <a class="pg-track-meta" href="{{ t.url }}" target="_blank" rel="noopener">
          <span class="pg-track-title">{{ t.title }}</span>
          <span class="pg-track-artist">{{ t.artist }}</span>
        </a>
      </li>
    {%- endfor -%}
  </ol>
  {%- if data.playlist_url -%}
    <a class="pg-songs-more" href="{{ data.playlist_url }}" target="_blank" rel="noopener">more on 网易云 →</a>
  {%- endif -%}
</div>
{%- else -%}
  <p class="pg-empty">
    No tracks yet — run <code>python3 scripts/fetch_liked_songs.py</code> to
    populate <code>_data/playlist_tracks.json</code>.
  </p>
{%- endif -%}
