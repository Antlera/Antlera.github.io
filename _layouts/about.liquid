---
layout: default
---
<div class="bebop-page">

  {% include bebop_hero.liquid %}

  {% if page.about_blurb %}
    <section class="bebop-section bebop-blurb">
      <div class="clearfix">{{ content }}</div>
    </section>
  {% endif %}

  {% if page.selected_papers %}
    <section class="bebop-section">
      {% include bebop_section_rule.liquid title="selected papers" id="papers" %}
      {% include bebop_papers_tabs.liquid %}
      <p class="bebop-more">
        <a href="{{ '/publications/' | relative_url }}">→ see all publications</a>
      </p>
    </section>
  {% endif %}

  {% if page.featured_projects %}
    <section class="bebop-section">
      {% include bebop_section_rule.liquid title="projects / systems" id="projects" %}
      {% include bebop_projects_grid.liquid %}
      <p class="bebop-more">
        <a href="{{ '/projects/' | relative_url }}">→ all projects</a>
      </p>
    </section>
  {% endif %}

  {% if page.news %}
    <section class="bebop-section">
      {% include bebop_section_rule.liquid title="news" id="news" %}
      {% include bebop_news.liquid limit=5 %}
      <p class="bebop-more">
        <a href="{{ '/news/' | relative_url }}">→ all news</a>
      </p>
    </section>
  {% endif %}

  {% if site.latest_posts.enabled %}
    <section class="bebop-section">
      {% include bebop_section_rule.liquid title="thoughts" id="thoughts" %}
      {% include bebop_writing.liquid limit=5 %}
      <p class="bebop-more">
        <a href="{{ '/blog/' | relative_url }}">→ all thoughts</a>
      </p>
    </section>
  {% endif %}

</div>
